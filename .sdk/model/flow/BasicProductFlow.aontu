# BasicProductFlow

main: kit: flow: BasicProductFlow:
{
  entity: "product",
  kind: "basic",
  name: "BasicProductFlow",
  step: [
    {
      op: "list",
      valid: [
        {
          apply: "ItemExists",
          def: {
            ref: "product_ref01"
          }
        }
      ]
    }

    {
      input: {
        ref: "product_ref01",
        srcdatavar: "product_ref01_data",
        suffix: "_dt0"
      }

      match: {
        id: "product01"
      }

      op: "load",
      valid: [
        {
          apply: "TextFieldMark",
          def: {
            mark: "Mark01-product_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicProductFlow"
}